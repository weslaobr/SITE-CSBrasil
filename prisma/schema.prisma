generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                   String              @id @default(cuid())
  name                 String?
  email                String?             @unique
  emailVerified        DateTime?
  image                String?
  steamId              String?             @unique
  steamMatchAuthCode   String?
  steamLatestMatchCode String?
  faceitNickname       String?
  gcNickname           String?
  gcLevel              Int?
  cs2Rank              String?
  adr                  Float?
  hsPercentage         Float?
  winRate              Float?
  matchesPlayed        Int                 @default(0)
  accounts             Account[]
  lobbiesCreated       Lobby[]             @relation("LobbyCreator")
  lobbyParticipations  LobbyPlayer[]
  matches              Match[]
  sessions             Session[]
  inventoryItems       UserInventoryItem[]
  mapVetoesCreated     MapVetoLobby[]      @relation("MapVetoCreator")
  mapVetoesParticipated MapVetoLobby[]     @relation("MapVetoOpponent")
  globalMatchPlayers   GlobalMatchPlayer[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Match {
  id           String   @id @default(cuid())
  userId       String
  source       String   @default("internal")
  externalId   String?  @unique
  gameMode     String?
  mapName      String
  kills        Int
  deaths       Int
  assists      Int
  score        String
  mvps         Int
  duration     String?
  url          String?
  matchDate    DateTime @default(now())
  result       String
  adr          Float?
  hsPercentage Float?
  metadata     Json?    @default("{}")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Lobby {
  id         String        @id @default(cuid())
  name       String
  password   String?
  status     String        @default("waiting")
  creatorId  String
  leaderAId  String?
  leaderBId  String?
  turn       String        @default("A")
  rpsEnabled Boolean       @default(false)
  rpsState   String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  creator    User          @relation("LobbyCreator", fields: [creatorId], references: [id])
  players    LobbyPlayer[]
}

model LobbyPlayer {
  id       String   @id @default(cuid())
  lobbyId  String
  userId   String
  team     String   @default("none")
  isLeader Boolean  @default(false)
  joinedAt DateTime @default(now())
  lobby    Lobby    @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([lobbyId, userId])
}

model GuildConfig {
  id               String            @id
  logChannelId     String?
  auditChannelId   String?
  enableAudit      Boolean           @default(true)
  enableVoice      Boolean           @default(true)
  updatedAt        DateTime          @updatedAt
  enableInvites    Boolean           @default(true)
  invitesChannelId String?
  rankingChannelId String?
  rankingMessageId String?
  enableRoleSync   Boolean           @default(false)
  AuditLogSetting  AuditLogSetting[]
  RoleMapping      RoleMapping[]
}

model Player {
  id           Int      @id @default(autoincrement())
  discordId    String   @unique
  steamId      String   @unique
  steamUrl     String
  faceitId     String?  @unique
  faceitName   String?
  leetifyId    String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  invitesCount Int      @default(0)
  referredById String?
  steamName    String?
  steamAvatar  String?
  Stats        Stats?
}

model RoleMapping {
  id          Int         @id @default(autoincrement())
  guildId     String
  minRating   Int
  roleId      String
  createdAt   DateTime    @default(now())
  GuildConfig GuildConfig @relation(fields: [guildId], references: [id])

  @@unique([guildId, minRating])
}

model Stats {
  id            Int      @id @default(autoincrement())
  playerId      Int      @unique
  leetifyRating Float?
  faceitElo     Int?
  faceitLevel   Int?
  updatedAt     DateTime @updatedAt
  gcLevel       Int?
  premierRating Int?
  Player        Player   @relation(fields: [playerId], references: [id])
}

model UserInventoryItem {
  id             String   @id @default(cuid())
  userId         String
  assetId        String
  marketHashName String
  paidPrice      Float?
  currency       String   @default("BRL")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, assetId])
}

model ItemPriceBase {
  id             String   @id @default(cuid())
  marketHashName String   @unique
  price          Float
  currency       String   @default("BRL")
  source         String   @default("csgotrader")
  lastUpdate     DateTime @default(now())
}

model AuditLogSetting {
  id          Int         @id @default(autoincrement())
  guildId     String
  key         String
  enabled     Boolean     @default(true)
  color       Int?
  GuildConfig GuildConfig @relation(fields: [guildId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([guildId, key])
}

model MapVetoLobby {
  id          String   @id @default(cuid())
  creatorId   String
  opponentId  String?
  format      String   @default("BO3")
  status      String   @default("WAITING")
  turn        String?
  rpsState    Json?    @default("{}")
  mapPool     Json?    @default("[\"Mirage\", \"Inferno\", \"Nuke\", \"Overpass\", \"Ancient\", \"Anubis\", \"Dust2\"]")
  knifeRound  Boolean  @default(false)
  vetoHistory Json?    @default("[]")
  timerStart  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  creator     User     @relation("MapVetoCreator", fields: [creatorId], references: [id])
  opponent    User?    @relation("MapVetoOpponent", fields: [opponentId], references: [id])
}

// Uma partida que ocorreu. Não pertence a apenas um User.
model GlobalMatch {
  id           String             @id // Ex: match_id da Valve ou Faceit
  source       String             @default("matchmaking") // matchmaking, faceit, mix
  mapName      String
  duration     String?
  matchDate    DateTime           @default(now())
  scoreA       Int?
  scoreB       Int?
  metadata     Json?              @default("{}") // Demo URL, etc.
  players      GlobalMatchPlayer[]
}

// O resultado de UM jogador dentro daquela partida (Serão 10 registros por GlobalMatch)
model GlobalMatchPlayer {
  id               String      @id @default(uuid())
  globalMatchId    String
  steamId          String      // Salvamos o SteamID, independente se ele já é um "User" do bot
  userId           String?     // Opcional, caso ele já tenha conta logada no site/bot
  team             String      // CT ou T, Equipe A ou B
  kills            Int
  deaths           Int
  assists          Int
  score            Int
  mvps             Int
  adr              Float?
  hsPercentage     Float?
  matchResult      String      // win, loss, tie
  metadata         Json?       @default("{}") // Armazena fk, fd, utilDmg, flashAssists, etc.
  
  match            GlobalMatch @relation(fields: [globalMatchId], references: [id], onDelete: Cascade)
  user             User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([globalMatchId, steamId])
}
