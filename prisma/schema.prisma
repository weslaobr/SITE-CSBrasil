generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  
  // Custom Tropa do CS2 fields
  steamId            String?   @unique
  steamMatchAuthCode String?
  steamLatestMatchCode String?
  faceitNickname     String?
  gcNickname         String?
  gcLevel            Int?
  cs2Rank            String?
  adr                Float?
  hsPercentage       Float?
  winRate            Float?
  matchesPlayed      Int       @default(0)

  accounts      Account[]
  sessions      Session[]
  matches       Match[]
  lobbiesCreated Lobby[] @relation("LobbyCreator")
  lobbyParticipations LobbyPlayer[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Match {
  id          String   @id @default(cuid())
  userId      String
  source      String   @default("internal") // "internal", "steam", "faceit", "gamersclub"
  externalId  String?  @unique
  gameMode    String?  // "premier", "competitive", "wingman"
  mapName     String
  kills       Int
  deaths      Int
  assists     Int
  score       String   // Changed from Int
  mvps        Int
  duration    String?  // New field
  url         String?  // New field
  matchDate   DateTime @default(now())
  result      String   // "Win", "Loss", "Tie"
  adr         Float?
  hsPercentage Float?
  metadata     Json?     @default("{}")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Lobby {
  id          String   @id @default(cuid())
  name        String
  password    String?
  status      String   @default("waiting") // "waiting", "picking", "finished"
  creatorId   String
  leaderAId   String?
  leaderBId   String?
  turn        String   @default("A") // "A" or "B"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator     User     @relation("LobbyCreator", fields: [creatorId], references: [id])
  players     LobbyPlayer[]
}

model LobbyPlayer {
  id        String   @id @default(cuid())
  lobbyId   String
  userId    String
  team      String   @default("none") // "none", "A", "B"
  isLeader  Boolean  @default(false)
  joinedAt  DateTime @default(now())

  lobby     Lobby    @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([lobbyId, userId])
}
