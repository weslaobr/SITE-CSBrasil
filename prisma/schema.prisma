generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                    String              @id @default(cuid())
  name                  String?
  email                 String?             @unique
  emailVerified         DateTime?
  image                 String?
  steamId               String?             @unique
  steamMatchAuthCode    String?
  steamLatestMatchCode  String?
  faceitNickname        String?
  gcNickname            String?
  gcLevel               Int?
  cs2Rank               String?
  adr                   Float?
  hsPercentage          Float?
  winRate               Float?
  matchesPlayed         Int                 @default(0)
  isAdmin               Boolean?            @default(false)
  accounts              Account[]
  evaluationLists       EvaluationList[]    @relation("EvaluationCreator")
  globalMatchPlayers    GlobalMatchPlayer[]
  lobbiesCreated        Lobby[]             @relation("LobbyCreator")
  lobbyParticipations   LobbyPlayer[]
  mapVetoesCreated      MapVetoLobby[]      @relation("MapVetoCreator")
  mapVetoesParticipated MapVetoLobby[]      @relation("MapVetoOpponent")
  matches               Match[]
  sessions              Session[]
  inventoryItems        UserInventoryItem[]
  crosshairs            Crosshair[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Match {
  id           String   @id @default(cuid())
  userId       String
  source       String   @default("internal")
  externalId   String?  @unique
  gameMode     String?
  mapName      String
  kills        Int
  deaths       Int
  assists      Int
  score        String
  mvps         Int
  duration     String?
  url          String?
  matchDate    DateTime @default(now())
  result       String
  adr          Float?
  hsPercentage Float?
  metadata     Json?    @default("{}")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Lobby {
  id         String        @id @default(cuid())
  name       String
  password   String?
  status     String        @default("waiting")
  creatorId  String
  leaderAId  String?
  leaderBId  String?
  turn       String        @default("A")
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  rpsEnabled Boolean       @default(false)
  rpsState   String?
  creator    User          @relation("LobbyCreator", fields: [creatorId], references: [id])
  players    LobbyPlayer[]
}

model LobbyPlayer {
  id       String   @id @default(cuid())
  lobbyId  String
  userId   String
  team     String   @default("none")
  isLeader Boolean  @default(false)
  joinedAt DateTime @default(now())
  lobby    Lobby    @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([lobbyId, userId])
}

model GuildConfig {
  id                   String            @id
  logChannelId         String?
  auditChannelId       String?
  enableAudit          Boolean           @default(true)
  enableVoice          Boolean           @default(true)
  updatedAt            DateTime          @updatedAt
  enableInvites        Boolean           @default(true)
  invitesChannelId     String?
  rankingChannelId     String?
  rankingMessageId     String?
  enableRoleSync       Boolean           @default(false)
  matchReportChannelId String?
  AuditLogSetting      AuditLogSetting[]
  AutoClearConfig      AutoClearConfig[]
  RoleMapping          RoleMapping[]
}

model Player {
  id           Int      @id @default(autoincrement())
  discordId    String   @unique
  steamId      String   @unique
  steamUrl     String
  faceitId     String?  @unique
  faceitName   String?
  leetifyId    String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  invitesCount Int      @default(0)
  referredById String?
  steamName    String?
  steamAvatar  String?
  Stats        Stats?
}

model RoleMapping {
  id          Int         @id @default(autoincrement())
  guildId     String
  minRating   Int
  roleId      String
  createdAt   DateTime    @default(now())
  GuildConfig GuildConfig @relation(fields: [guildId], references: [id])

  @@unique([guildId, minRating])
}

model Stats {
  id            Int      @id @default(autoincrement())
  playerId      Int      @unique
  leetifyRating Float?
  faceitElo     Int?
  faceitLevel   Int?
  updatedAt     DateTime @updatedAt
  gcLevel       Int?
  premierRating Int?
  Player        Player   @relation(fields: [playerId], references: [id])
}

model UserInventoryItem {
  id             String   @id @default(cuid())
  userId         String
  assetId        String
  marketHashName String
  paidPrice      Float?
  currency       String   @default("BRL")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, assetId])
}

model ItemPriceBase {
  id             String   @id @default(cuid())
  marketHashName String   @unique
  price          Float
  currency       String   @default("BRL")
  source         String   @default("csgotrader")
  lastUpdate     DateTime @default(now())
}

model AuditLogSetting {
  id          Int         @id @default(autoincrement())
  guildId     String
  key         String
  enabled     Boolean     @default(true)
  color       Int?
  GuildConfig GuildConfig @relation(fields: [guildId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([guildId, key])
}

model MapVetoLobby {
  id          String    @id @default(cuid())
  creatorId   String
  opponentId  String?
  format      String    @default("BO3")
  status      String    @default("WAITING")
  turn        String?
  rpsState    Json?     @default("{}")
  mapPool     Json?     @default("[\"Mirage\", \"Inferno\", \"Nuke\", \"Vertigo\", \"Ancient\", \"Anubis\", \"Dust2\"]")
  vetoHistory Json?     @default("[]")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  timerStart  DateTime?
  knifeRound  Boolean?  @default(false)
  creator     User      @relation("MapVetoCreator", fields: [creatorId], references: [id])
  opponent    User?     @relation("MapVetoOpponent", fields: [opponentId], references: [id])
}

model GlobalMatch {
  id        String              @id
  source    String              @default("matchmaking")
  mapName   String
  duration  String?
  matchDate DateTime            @default(now())
  scoreA    Int?
  scoreB    Int?
  metadata  Json?               @default("{}")
  players   GlobalMatchPlayer[]
}

model GlobalMatchPlayer {
  id            String      @id @default(uuid())
  globalMatchId String
  steamId       String
  userId        String?
  team          String
  kills         Int
  deaths        Int
  assists       Int
  score         Int
  mvps          Int
  adr           Float?
  hsPercentage  Float?
  matchResult   String
  metadata      Json?       @default("{}")
  match         GlobalMatch @relation(fields: [globalMatchId], references: [id], onDelete: Cascade)
  user          User?       @relation(fields: [userId], references: [id])

  @@unique([globalMatchId, steamId])
}

model Tournament {
  id          String            @id @default(cuid())
  name        String
  description String?
  format      String            @default("BO1")
  status      String            @default("OPEN")
  creatorId   String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @default(now()) @updatedAt
  matches     TournamentMatch[]
  teams       TournamentTeam[]
}

model TournamentTeam {
  id           String            @id @default(cuid())
  tournamentId String
  name         String
  playerIds    Json              @default("[]")
  createdAt    DateTime          @default(now())
  matchesA     TournamentMatch[] @relation("TeamA")
  matchesB     TournamentMatch[] @relation("TeamB")
  wins         TournamentMatch[] @relation("Winner")
  tournament   Tournament        @relation(fields: [tournamentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model TournamentMatch {
  id           String          @id @default(cuid())
  tournamentId String
  teamAId      String
  teamBId      String
  winnerId     String?
  scoreA       Int?
  scoreB       Int?
  round        Int             @default(1)
  status       String          @default("PENDING")
  mapName      String?
  createdAt    DateTime        @default(now())
  teamA        TournamentTeam  @relation("TeamA", fields: [teamAId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  teamB        TournamentTeam  @relation("TeamB", fields: [teamBId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tournament   Tournament      @relation(fields: [tournamentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  winner       TournamentTeam? @relation("Winner", fields: [winnerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model EvaluationList {
  id          String             @id @default(cuid())
  creatorId   String
  title       String
  description String?
  isPublic    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @default(now()) @updatedAt
  creator     User               @relation("EvaluationCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  evaluations PlayerEvaluation[]
}

model PlayerEvaluation {
  id                  String         @id @default(cuid())
  listId              String
  evaluatedPlayerName String
  evaluatedSteamId    String?
  aimScore            Float
  utilityScore        Float
  positioningScore    Float
  duelScore           Float
  clutchScore         Float
  decisionScore       Float
  overallScore        Float
  notes               String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @default(now()) @updatedAt
  list                EvaluationList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@unique([listId, evaluatedPlayerName])
}

model AutoClearConfig {
  id           Int         @id @default(autoincrement())
  guildId      String
  channelId    String
  interval     Int
  amount       Int         @default(100)
  ignorePinned Boolean     @default(true)
  enabled      Boolean     @default(true)
  lastRun      DateTime?
  GuildConfig  GuildConfig @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, channelId])
}

model Crosshair {
  id          String   @id @default(cuid())
  userId      String
  name        String
  code        String
  description String?
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
