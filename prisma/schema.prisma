generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                   String              @id @default(cuid())
  name                 String?
  email                String?             @unique
  emailVerified        DateTime?
  image                String?
  steamId              String?             @unique
  steamMatchAuthCode   String?
  steamLatestMatchCode String?
  faceitNickname       String?
  gcNickname           String?
  gcLevel              Int?
  cs2Rank              String?
  adr                  Float?
  hsPercentage         Float?
  winRate              Float?
  matchesPlayed        Int                 @default(0)
  accounts             Account[]
  lobbiesCreated       Lobby[]             @relation("LobbyCreator")
  lobbyParticipations  LobbyPlayer[]
  matches              Match[]
  sessions             Session[]
  inventoryItems       UserInventoryItem[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Match {
  id           String   @id @default(cuid())
  userId       String
  source       String   @default("internal")
  externalId   String?  @unique
  gameMode     String?
  mapName      String
  kills        Int
  deaths       Int
  assists      Int
  score        String
  mvps         Int
  duration     String?
  url          String?
  matchDate    DateTime @default(now())
  result       String
  adr          Float?
  hsPercentage Float?
  metadata     Json?    @default("{}")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Lobby {
  id        String        @id @default(cuid())
  name      String
  password  String?
  status    String        @default("waiting")
  creatorId String
  leaderAId String?
  leaderBId String?
  turn      String        @default("A")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  creator   User          @relation("LobbyCreator", fields: [creatorId], references: [id])
  players   LobbyPlayer[]
}

model LobbyPlayer {
  id       String   @id @default(cuid())
  lobbyId  String
  userId   String
  team     String   @default("none")
  isLeader Boolean  @default(false)
  joinedAt DateTime @default(now())
  lobby    Lobby    @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([lobbyId, userId])
}

model GuildConfig {
  id               String        @id
  logChannelId     String?
  auditChannelId   String?
  enableAudit      Boolean       @default(true)
  enableVoice      Boolean       @default(true)
  updatedAt        DateTime      @updatedAt
  enableInvites    Boolean       @default(true)
  invitesChannelId String?
  rankingChannelId String?
  rankingMessageId String?
  enableRoleSync   Boolean       @default(false)
  RoleMapping      RoleMapping[]
}

model Player {
  id           Int      @id @default(autoincrement())
  discordId    String   @unique
  steamId      String   @unique
  steamUrl     String
  faceitId     String?  @unique
  faceitName   String?
  leetifyId    String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  invitesCount Int      @default(0)
  referredById String?
  Stats        Stats?
}

model RoleMapping {
  id          Int         @id @default(autoincrement())
  guildId     String
  minRating   Int
  roleId      String
  createdAt   DateTime    @default(now())
  GuildConfig GuildConfig @relation(fields: [guildId], references: [id])

  @@unique([guildId, minRating])
}

model Stats {
  id            Int      @id @default(autoincrement())
  playerId      Int      @unique
  leetifyRating Float?
  faceitElo     Int?
  faceitLevel   Int?
  updatedAt     DateTime @updatedAt
  gcLevel       Int?
  premierRating Int?
  Player        Player   @relation(fields: [playerId], references: [id])
}

// --- Novos Modelos de Inventário e Preços ---

model UserInventoryItem {
  id            String   @id @default(cuid())
  userId        String
  assetId       String   // ID único do item no inventário Steam
  marketHashName String  // Nome em inglês para referência de preço
  paidPrice     Float?   // Preço pago pelo usuário
  currency      String   @default("BRL")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, assetId])
}

model ItemPriceBase {
  id             String   @id @default(cuid())
  marketHashName String   @unique // Chave única (ex: AK-47 | Redline (Field-Tested))
  price          Float
  currency       String   @default("BRL")
  source         String   @default("csgotrader")
  lastUpdate     DateTime @default(now())
}
