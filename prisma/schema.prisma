generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                    String              @id @default(cuid())
  name                  String?
  email                 String?             @unique
  emailVerified         DateTime?
  image                 String?
  steamId               String?             @unique
  steamMatchAuthCode    String?
  steamLatestMatchCode  String?
  faceitNickname        String?
  gcNickname            String?
  gcLevel               Int?
  cs2Rank               String?
  adr                   Float?
  hsPercentage          Float?
  winRate               Float?
  matchesPlayed         Int                 @default(0)
  isAdmin               Boolean?            @default(false)
  rankingPoints         Int?                @default(500)
  mixLevel              Int?                @default(5)
  accounts              Account[]
  crosshairs            Crosshair[]
  evaluationLists       EvaluationList[]    @relation("EvaluationCreator")
  globalMatchPlayers    GlobalMatchPlayer[]
  lobbiesCreated        Lobby[]             @relation("LobbyCreator")
  lobbyParticipations   LobbyPlayer[]
  mapVetoesCreated      MapVetoLobby[]      @relation("MapVetoCreator")
  mapVetoesParticipated MapVetoLobby[]      @relation("MapVetoOpponent")
  matches               Match[]
  sessions              Session[]
  inventoryItems        UserInventoryItem[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Match {
  id           String   @id @default(cuid())
  userId       String
  source       String   @default("internal")
  externalId   String?  @unique
  gameMode     String?
  mapName      String
  kills        Int
  deaths       Int
  assists      Int
  score        String
  mvps         Int
  duration     String?
  url          String?
  matchDate    DateTime @default(now())
  result       String
  adr          Float?
  hsPercentage Float?
  metadata     Json?    @default("{}")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Lobby {
  id         String        @id @default(cuid())
  name       String
  password   String?
  status     String        @default("waiting")
  creatorId  String
  leaderAId  String?
  leaderBId  String?
  turn       String        @default("A")
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  rpsEnabled Boolean       @default(false)
  rpsState   String?
  creator    User          @relation("LobbyCreator", fields: [creatorId], references: [id])
  players    LobbyPlayer[]
}

model LobbyPlayer {
  id       String   @id @default(cuid())
  lobbyId  String
  userId   String
  team     String   @default("none")
  isLeader Boolean  @default(false)
  joinedAt DateTime @default(now())
  lobby    Lobby    @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([lobbyId, userId])
}

model GuildConfig {
  id                   String            @id
  logChannelId         String?
  auditChannelId       String?
  enableAudit          Boolean           @default(true)
  enableVoice          Boolean           @default(true)
  updatedAt            DateTime          @updatedAt
  enableInvites        Boolean           @default(true)
  invitesChannelId     String?
  rankingChannelId     String?
  rankingMessageId     String?
  enableRoleSync       Boolean           @default(false)
  matchReportChannelId String?
  AuditLogSetting      AuditLogSetting[]
  AutoClearConfig      AutoClearConfig[]
  RoleMapping          RoleMapping[]
}

model Player {
  id           Int      @id @default(autoincrement())
  discordId    String   @unique
  steamId      String   @unique
  steamUrl     String
  faceitId     String?  @unique
  faceitName   String?
  leetifyId    String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  invitesCount Int      @default(0)
  referredById String?
  steamName    String?
  steamAvatar  String?
  Stats        Stats?
}

model RoleMapping {
  id          Int         @id @default(autoincrement())
  guildId     String
  minRating   Int
  roleId      String
  createdAt   DateTime    @default(now())
  GuildConfig GuildConfig @relation(fields: [guildId], references: [id])

  @@unique([guildId, minRating])
}

model Stats {
  id            Int      @id @default(autoincrement())
  playerId      Int      @unique
  leetifyRating Float?
  faceitElo     Int?
  faceitLevel   Int?
  updatedAt     DateTime @updatedAt
  gcLevel       Int?
  premierRating Int?
  Player        Player   @relation(fields: [playerId], references: [id])
}

model UserInventoryItem {
  id             String   @id @default(cuid())
  userId         String
  assetId        String
  marketHashName String
  paidPrice      Float?
  currency       String   @default("BRL")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, assetId])
}

model ItemPriceBase {
  id             String   @id @default(cuid())
  marketHashName String   @unique
  price          Float
  currency       String   @default("BRL")
  source         String   @default("csgotrader")
  lastUpdate     DateTime @default(now())
}

model AuditLogSetting {
  id          Int         @id @default(autoincrement())
  guildId     String
  key         String
  enabled     Boolean     @default(true)
  color       Int?
  GuildConfig GuildConfig @relation(fields: [guildId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([guildId, key])
}

model MapVetoLobby {
  id          String    @id @default(cuid())
  creatorId   String
  opponentId  String?
  format      String    @default("BO3")
  status      String    @default("WAITING")
  turn        String?
  rpsState    Json?     @default("{}")
  mapPool     Json?     @default("[\"Mirage\", \"Inferno\", \"Nuke\", \"Vertigo\", \"Ancient\", \"Anubis\", \"Dust2\"]")
  vetoHistory Json?     @default("[]")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  timerStart  DateTime?
  knifeRound  Boolean?  @default(false)
  creator     User      @relation("MapVetoCreator", fields: [creatorId], references: [id])
  opponent    User?     @relation("MapVetoOpponent", fields: [opponentId], references: [id])
}

model GlobalMatch {
  id        String              @id
  source    String              @default("matchmaking")
  mapName   String
  duration  String?
  matchDate DateTime            @default(now())
  scoreA    Int?
  scoreB    Int?
  metadata  Json?               @default("{}")
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  players   GlobalMatchPlayer[]
}

model GlobalMatchPlayer {
  id            String      @id @default(uuid())
  globalMatchId String
  steamId       String
  userId        String?
  team          String
  kills         Int
  deaths        Int
  assists       Int
  score         Int
  mvps          Int
  adr           Float?
  hsPercentage  Float?
  matchResult   String
  metadata      Json?       @default("{}")
  eloChange     Int?
  eloAfter      Int?
  match         GlobalMatch @relation(fields: [globalMatchId], references: [id], onDelete: Cascade)
  user          User?       @relation(fields: [userId], references: [id])

  @@unique([globalMatchId, steamId])
}

model Tournament {
  id          String            @id @default(cuid())
  name        String
  description String?
  format      String            @default("BO1")
  status      String            @default("OPEN")
  creatorId   String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @default(now()) @updatedAt
  matches     TournamentMatch[]
  teams       TournamentTeam[]
}

model TournamentTeam {
  id           String            @id @default(cuid())
  tournamentId String
  name         String
  playerIds    Json              @default("[]")
  createdAt    DateTime          @default(now())
  matchesA     TournamentMatch[] @relation("TeamA")
  matchesB     TournamentMatch[] @relation("TeamB")
  wins         TournamentMatch[] @relation("Winner")
  tournament   Tournament        @relation(fields: [tournamentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model TournamentMatch {
  id           String          @id @default(cuid())
  tournamentId String
  teamAId      String
  teamBId      String
  winnerId     String?
  scoreA       Int?
  scoreB       Int?
  round        Int             @default(1)
  status       String          @default("PENDING")
  mapName      String?
  createdAt    DateTime        @default(now())
  teamA        TournamentTeam  @relation("TeamA", fields: [teamAId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  teamB        TournamentTeam  @relation("TeamB", fields: [teamBId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tournament   Tournament      @relation(fields: [tournamentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  winner       TournamentTeam? @relation("Winner", fields: [winnerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model EvaluationList {
  id          String             @id @default(cuid())
  creatorId   String
  title       String
  description String?
  isPublic    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @default(now()) @updatedAt
  creator     User               @relation("EvaluationCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  evaluations PlayerEvaluation[]
}

model PlayerEvaluation {
  id                  String         @id @default(cuid())
  listId              String
  evaluatedPlayerName String
  evaluatedSteamId    String?
  aimScore            Float
  utilityScore        Float
  positioningScore    Float
  duelScore           Float
  clutchScore         Float
  decisionScore       Float
  overallScore        Float
  notes               String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @default(now()) @updatedAt
  list                EvaluationList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@unique([listId, evaluatedPlayerName])
}

model AutoClearConfig {
  id           Int         @id @default(autoincrement())
  guildId      String
  channelId    String
  interval     Int
  amount       Int         @default(100)
  ignorePinned Boolean     @default(true)
  enabled      Boolean     @default(true)
  lastRun      DateTime?
  GuildConfig  GuildConfig @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, channelId])
}

model Crosshair {
  id           String   @id @default(cuid())
  userId       String
  name         String
  code         String
  description  String?
  isPublic     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
  previewColor String?  @default("#00ff00")
  previewSize  Float?   @default(5)
  previewGap   Float?   @default(0)
  previewThick Float?   @default(1)
  previewDot   Boolean? @default(false)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "crosshair_userid_fkey")
}

model tracker_clutch_events {
  clutch_id       Int              @id @default(autoincrement())
  match_id        String?
  round_id        Int?
  steamid64       BigInt?
  clutch_type     String?          @db.VarChar
  is_won          Boolean?
  tracker_matches tracker_matches? @relation(fields: [match_id], references: [match_id], onDelete: Cascade, onUpdate: NoAction)
  tracker_rounds  tracker_rounds?  @relation(fields: [round_id], references: [round_id], onDelete: Cascade, onUpdate: NoAction)
  tracker_players tracker_players? @relation(fields: [steamid64], references: [steamid64], onDelete: NoAction, onUpdate: NoAction)
}

model tracker_damage_events {
  damage_id        Int              @id @default(autoincrement())
  match_id         String?
  round_id         Int?
  tick             Int
  attacker_steamid BigInt?
  victim_steamid   BigInt?
  weapon           String?
  hp_damage        Int?
  armor_damage     Int?
  hitgroup         Int?
  tracker_matches  tracker_matches? @relation(fields: [match_id], references: [match_id], onDelete: Cascade, onUpdate: NoAction)
  tracker_rounds   tracker_rounds?  @relation(fields: [round_id], references: [round_id], onDelete: Cascade, onUpdate: NoAction)
}

model tracker_grenade_events {
  grenade_id      Int              @id @default(autoincrement())
  match_id        String?
  round_id        Int?
  tick            Int
  steamid64       BigInt?
  grenade_type    String?
  x               Float?
  y               Float?
  z               Float?
  blind_duration  Float?
  tracker_matches tracker_matches? @relation(fields: [match_id], references: [match_id], onDelete: Cascade, onUpdate: NoAction)
  tracker_rounds  tracker_rounds?  @relation(fields: [round_id], references: [round_id], onDelete: Cascade, onUpdate: NoAction)
}

model tracker_kill_events {
  kill_id                                                               Int              @id @default(autoincrement())
  match_id                                                              String?
  round_id                                                              Int?
  tick                                                                  Int
  attacker_steamid                                                      BigInt?
  victim_steamid                                                        BigInt?
  assister_steamid                                                      BigInt?
  weapon                                                                String?
  is_headshot                                                           Boolean?
  is_wallbang                                                           Boolean?
  attacker_x                                                            Float?
  attacker_y                                                            Float?
  attacker_z                                                            Float?
  victim_x                                                              Float?
  victim_y                                                              Float?
  victim_z                                                              Float?
  distance                                                              Float?
  tracker_players_tracker_kill_events_attacker_steamidTotracker_players tracker_players? @relation("tracker_kill_events_attacker_steamidTotracker_players", fields: [attacker_steamid], references: [steamid64], onDelete: NoAction, onUpdate: NoAction)
  tracker_matches                                                       tracker_matches? @relation(fields: [match_id], references: [match_id], onDelete: Cascade, onUpdate: NoAction)
  tracker_rounds                                                        tracker_rounds?  @relation(fields: [round_id], references: [round_id], onDelete: Cascade, onUpdate: NoAction)
  tracker_players_tracker_kill_events_victim_steamidTotracker_players   tracker_players? @relation("tracker_kill_events_victim_steamidTotracker_players", fields: [victim_steamid], references: [steamid64], onDelete: NoAction, onUpdate: NoAction)
}

model tracker_match_players {
  match_id             String
  steamid64            BigInt
  team                 String?
  kills                Int?
  deaths               Int?
  assists              Int?
  adr                  Float?
  kast                 Float?
  rating               Float?
  hs_count             Int?
  utility_damage       Int?
  flash_assists        Int?
  fk                   Int?
  fd                   Int?
  triples              Int?
  quads                Int?
  aces                 Int?
  clutches             Int?
  trades               Int?
  enemies_flashed      Int?
  total_blind_duration Float?
  avg_kill_distance    Float?
  avg_ttd              Float?
  utility_damage_roi   Float?
  he_thrown            Int?            @default(0)
  flash_thrown         Int?            @default(0)
  smokes_thrown        Int?            @default(0)
  molotovs_thrown      Int?            @default(0)
  elo_change           Int?
  elo_after            Int?
  tracker_matches      tracker_matches @relation(fields: [match_id], references: [match_id], onDelete: Cascade, onUpdate: NoAction)
  tracker_players      tracker_players @relation(fields: [steamid64], references: [steamid64], onDelete: NoAction, onUpdate: NoAction)

  @@id([match_id, steamid64])
}

model tracker_matches {
  match_id               String                   @id
  map_name               String
  match_date             DateTime?                @default(now()) @db.Timestamptz(6)
  duration_seconds       Int?
  score_ct               Int?
  score_t                Int?
  winner_team            String?
  demo_url               String?
  is_parsed              Boolean?
  parsed_at              DateTime?                @db.Timestamptz(6)
  source                 String?
  tracker_clutch_events  tracker_clutch_events[]
  tracker_damage_events  tracker_damage_events[]
  tracker_grenade_events tracker_grenade_events[]
  tracker_kill_events    tracker_kill_events[]
  tracker_match_players  tracker_match_players[]
  tracker_rounds         tracker_rounds[]
  tracker_weapon_stats   tracker_weapon_stats[]
}

model tracker_players {
  steamid64                                                                 BigInt                  @id @default(autoincrement())
  personaname                                                               String?
  avatar_url                                                                String?
  last_updated                                                              DateTime?               @default(now()) @db.Timestamptz(6)
  tracker_clutch_events                                                     tracker_clutch_events[]
  tracker_kill_events_tracker_kill_events_attacker_steamidTotracker_players tracker_kill_events[]   @relation("tracker_kill_events_attacker_steamidTotracker_players")
  tracker_kill_events_tracker_kill_events_victim_steamidTotracker_players   tracker_kill_events[]   @relation("tracker_kill_events_victim_steamidTotracker_players")
  tracker_match_players                                                     tracker_match_players[]
  tracker_weapon_stats                                                      tracker_weapon_stats[]
}

model tracker_rounds {
  round_id               Int                      @id @default(autoincrement())
  match_id               String?
  round_number           Int
  winner_side            String?
  reason                 String?
  end_tick               Int?
  ct_equipment_value     Int?
  t_equipment_value      Int?
  ct_buy_type            String?
  t_buy_type             String?
  tracker_clutch_events  tracker_clutch_events[]
  tracker_damage_events  tracker_damage_events[]
  tracker_grenade_events tracker_grenade_events[]
  tracker_kill_events    tracker_kill_events[]
  tracker_matches        tracker_matches?         @relation(fields: [match_id], references: [match_id], onDelete: Cascade, onUpdate: NoAction)
}

model tracker_weapon_stats {
  id              Int              @id @default(autoincrement())
  match_id        String?
  steamid64       BigInt?
  weapon          String
  kills           Int?
  headshots       Int?
  damage          Int?
  accuracy        Float?
  tracker_matches tracker_matches? @relation(fields: [match_id], references: [match_id], onDelete: Cascade, onUpdate: NoAction)
  tracker_players tracker_players? @relation(fields: [steamid64], references: [steamid64], onDelete: NoAction, onUpdate: NoAction)
}
